<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Kiosco Asistencia UI - Glassmorphism</title>
    <!-- Fuentes -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>
        /* DISEÑO LIQUID GLASS / GLASSMORPHISM */
        :root {
            --accent: #38bdf8; /* Cyan/Azul moderno */
            --accent-glow: rgba(56, 189, 248, 0.6);
            --accent-out: #f43f5e; /* Rojo rosado/Salida */
            --accent-out-glow: rgba(244, 63, 94, 0.6);
            --text-main: #ffffff;
            --text-muted: #cbd5e1;
            --danger: #ef4444;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-border-light: rgba(255, 255, 255, 0.2);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }

        body {
            background-color: #05050a;
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            overflow: hidden;
            width: 100vw;
            height: 100vh;
        }

        /* --- FONDO ANIMADO LIQUID GLASS --- */
        .ambient-bg {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: -1;
            background: #020617;
            overflow: hidden;
        }
        .blob {
            position: absolute;
            filter: blur(100px);
            opacity: 0.5;
            animation: float 20s infinite ease-in-out alternate;
            border-radius: 50%;
        }
        .blob-1 { width: 700px; height: 700px; background: #8a4d91; top: -20%; left: -10%; }
        .blob-2 { width: 800px; height: 800px; background: #fb8ff0; bottom: -30%; right: -10%; animation-delay: -5s; }
        .blob-3 { width: 600px; height: 600px; background: #ec63ff; top: 40%; left: 30%; animation-delay: -10s; }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(100px, 80px) scale(1.15); }
        }

        /* --- CLASE MAESTRA: PANEL DE CRISTAL --- */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid var(--glass-border);
            border-top: 1px solid var(--glass-border-light);
            border-left: 1px solid var(--glass-border-light);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), inset 0 0 20px rgba(255, 255, 255, 0.02);
            border-radius: 32px;
        }

        h1, h2, h3 { font-family: 'Plus Jakarta Sans', sans-serif; }

        /* Sistema de Pantallas */
        .screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.5s ease, visibility 0.5s;
        }
        .screen.active { opacity: 1; visibility: visible; }

        /* --- 1. PANTALLA DE ARRANQUE --- */
        .spinner {
            width: 60px; height: 60px;
            border: 4px solid rgba(255, 255, 255, 0.1);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-top: 30px;
        }
        @keyframes spin { 100% { transform: rotate(360deg); } }

        /* --- 2. PANTALLA DE ESPERA --- */

        /* Hora Esquina Superior Izquierda */
        .top-left-time {
            position: absolute;
            top: 50px;
            left: 60px;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            text-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }
        .clock {
            font-size: 6rem;
            font-weight: 700;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-main);
            line-height: 1;
            letter-spacing: -2px;
        }
        .date {
            font-size: 1.5rem;
            color: var(--text-muted);
            margin-top: 8px;
            font-weight: 300;
        }

        /* Mensaje Parpadeante Inferior */
        .blinking-instruction {
            position: absolute;
            bottom: 120px;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
            width: 100%;
        }
        .blinking-instruction h2 {
            font-size: 2.8rem;
            font-weight: 400;
            letter-spacing: 1px;
            color: var(--text-main);
            animation: slowGlow 3s ease-in-out infinite;
        }
        .blinking-instruction p {
            font-size: 1.2rem;
            color: rgba(255,255,255,0.5);
            margin-top: 10px;
            font-weight: 300;
        }

        @keyframes slowGlow {
            0%, 100% { opacity: 0.4; text-shadow: 0 0 10px rgba(255,255,255,0); }
            50% { opacity: 1; text-shadow: 0 0 30px rgba(255,255,255,0.7), 0 0 10px rgba(255,255,255,0.3); }
        }

        /* --- 3. PANTALLAS DE PERFIL (ENTRADA Y SALIDA) --- */
        .student-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 60px 50px;
            width: 85%;
            max-width: 900px;
            position: relative;
            overflow: hidden;
        }

        /* Línea superior luminosa */
        .card-glow-line {
            position: absolute; top: 0; left: 0; right: 0; height: 5px;
            background: var(--accent);
            box-shadow: 0 0 20px var(--accent-glow);
        }
        #farewell-screen .card-glow-line {
            background: var(--accent-out);
            box-shadow: 0 0 20px var(--accent-out-glow);
        }

        .status-badge {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 8px 20px;
            border-radius: 30px;
            color: var(--accent);
            font-weight: 500;
            letter-spacing: 1px;
            text-transform: uppercase;
            font-size: 1rem;
            margin-bottom: 25px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        #farewell-screen .status-badge { color: var(--accent-out); }

        .student-info h1 {
            font-size: 5rem;
            margin-bottom: 15px;
            line-height: 1.1;
            text-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }
        .student-info p.matricula {
            font-size: 1.5rem;
            color: var(--text-muted);
            font-weight: 300;
        }

        .class-info {
            margin-top: 35px;
            background: rgba(0, 0, 0, 0.2);
            padding: 20px 40px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            display: inline-block;
        }
        .class-info strong { color: var(--text-main); font-size: 1.6rem; font-weight: 500;}

        /* --- 4. EXCEPCIÓN: DOBLE ESCANEO --- */
        .action-btn {
            background: rgba(255,255,255,0.05);
            color: var(--text-main);
            border: 1px solid rgba(255,255,255,0.2);
            padding: 20px 40px;
            border-radius: 20px;
            font-size: 1.4rem;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 500;
            backdrop-filter: blur(10px);
        }
        .action-btn.exit-btn:hover {
            border-color: var(--accent-out);
            background: rgba(244, 63, 94, 0.15);
            box-shadow: 0 10px 30px rgba(244, 63, 94, 0.2);
            transform: translateY(-3px);
        }
        .action-btn.info-btn:hover {
            border-color: var(--accent);
            background: rgba(56, 189, 248, 0.15);
            box-shadow: 0 10px 30px rgba(56, 189, 248, 0.2);
            transform: translateY(-3px);
        }

        /* --- 5. INFO ACADÉMICA INTERACTIVA --- */
        .academic-panel {
            width: 90%;
            max-width: 1000px;
            height: 75%;
            padding: 50px;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }
        .close-btn {
            align-self: center;
            background: rgba(255,255,255,0.1);
            color: var(--text-main);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 15px 40px;
            border-radius: 20px;
            font-size: 1.1rem;
            cursor: pointer;
            margin-top: 20px;
            transition: background 0.3s;
        }
        .close-btn:hover { background: rgba(255,255,255,0.2); }

        /* Barra de progreso de cierre automático tipo píldora flotante */
        .timeout-bar-container {
            position: absolute;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            width: 40%;
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
            overflow: hidden;
        }
        .timeout-bar {
            height: 100%;
            background-color: var(--accent);
            width: 100%;
            border-radius: 10px;
            box-shadow: 0 0 15px var(--accent-glow);
            transition: width 5s linear;
        }
        #farewell-screen .timeout-bar { background-color: var(--accent-out); box-shadow: 0 0 15px var(--accent-out-glow); }

        /* --- 6. PANTALLA ADMIN --- */
        .pin-pad { padding: 50px; text-align: center; width: 90%; max-width: 450px; }
        .admin-form { display: flex; flex-direction: column; gap: 20px; margin-bottom: 35px; text-align: left; }
        .admin-form label { color: var(--text-muted); font-size: 0.95rem; margin-bottom: -12px; font-weight: 400; padding-left: 5px;}
        .admin-form input {
            background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);
            color: white; padding: 15px 20px; border-radius: 16px; font-size: 1rem;
            outline: none; transition: all 0.3s; font-family: 'Inter', sans-serif;
        }
        .admin-form input:focus { border-color: var(--accent); background: rgba(0,0,0,0.5); box-shadow: 0 0 15px rgba(56, 189, 248, 0.2); }
        .admin-actions { display: flex; gap: 15px; justify-content: center; }
        .admin-btn { padding: 15px 25px; border: none; border-radius: 16px; font-weight: 500; cursor: pointer; font-size: 1rem; transition: opacity 0.2s; }
        .admin-btn.btn-cancel { background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.05); }
        .admin-btn.btn-login { background: var(--accent); color: #000; flex-grow: 1; box-shadow: 0 10px 20px var(--accent-glow); }
        .admin-btn:hover { opacity: 0.8; }

        #secret-trigger { position: absolute; top: 0; right: 0; width: 100px; height: 100px; z-index: 100; }

        /* --- NOTIFICACIONES Y ESTADO DE SISTEMA --- */

        /* Destello rojo sutil Glassmorphism */
        #error-overlay {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            box-shadow: inset 0 0 0 0 rgba(244, 63, 94, 0);
            pointer-events: none; z-index: 999;
        }
        #error-overlay.flash { animation: flashRed 1.2s ease-out 2; }
        @keyframes flashRed {
            0%, 100% { box-shadow: inset 0 0 0 0 rgba(244, 63, 94, 0); }
            50% { box-shadow: inset 0 0 100px 30px rgba(244, 63, 94, 0.4); }
        }

        /* Clase maestra para píldoras de notificación */
        .notification-pill {
            position: absolute;
            background: rgba(20, 20, 30, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text-main);
            padding: 15px 25px;
            border-radius: 30px;
            font-size: 1.1rem;
            font-weight: 400;
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
            z-index: 1000;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        #error-notification {
            top: 40px; right: -500px;
            transition: right 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            max-width: 450px;
        }
        #error-notification.show { right: 40px; }
        .icon-circle-error {
            background: rgba(244, 63, 94, 0.2); color: var(--accent-out);
            width: 40px; height: 40px; border-radius: 50%;
            display: flex; justify-content: center; align-items: center; font-size: 1.2rem;
        }

        #connection-warning {
            top: 40px; left: -500px;
            transition: left 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        #connection-warning.show { left: 40px; }

        .small-spinner {
            width: 20px; height: 20px;
            border: 3px solid rgba(255,255,255,0.1);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        /* Indicador Permanente (Pantalla Principal) */
        .system-status {
            top: 40px; right: 40px;
        }
        .pulse-icon { animation: pulse-cyan 1.5s infinite alternate; }
        @keyframes pulse-cyan {
            0% { opacity: 0.5; text-shadow: 0 0 0 rgba(0,0,0,0); }
            100% { opacity: 1; text-shadow: 0 0 15px var(--accent-glow); }
        }

        /* --- CONTROLES DE MUESTRA (FOOTER) --- */
        .demo-controls {
            position: absolute;
            bottom: 20px;
            display: flex;
            gap: 12px;
            z-index: 50;
            flex-wrap: wrap;
            justify-content: center;
        }
        .demo-controls button {
        }
        .demo-controls button:hover {
            color: white;
            background: rgba(255,255,255,0.1);
        }
    </style>
</head>
<body>

<!-- FONDO AMBIENTAL ANIMADO -->
<div class="ambient-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
</div>

<!-- DISPARADOR SECRETO ADMIN -->
<div id="secret-trigger" onclick="adminClicks()"></div>

<!-- DESTELLO ROJO EN BORDES (ERROR) -->
<div id="error-overlay"></div>

<!-- AVISO ERROR (SUPERIOR DERECHA) -->
<div id="error-notification" class="notification-pill">
    <div class="icon-circle-error"><i class="fa-solid fa-triangle-exclamation"></i></div>
    <span id="error-msg">El código no fue registrado, por favor intente de nuevo.</span>
</div>

<!-- AVISO CONEXIÓN BD (SUPERIOR IZQUIERDA) -->
<div id="connection-warning" class="notification-pill">
    <div class="small-spinner"></div>
    <span id="warning-msg">Sincronizando con Base de Datos local...</span>
</div>

<!-- 1. PANTALLA DE ARRANQUE -->
<div id="splash-screen" class="screen active">
    <h2 style="font-size: 2.5rem; font-weight: 300;">Iniciando Sistema</h2>
    <p style="color: var(--text-muted); margin-top: 15px; letter-spacing: 1px;">Conectando</p>
    <div class="spinner"></div>
</div>

<!-- 2. PANTALLA DE ESPERA (IDLE) -->
<div id="idle-screen" class="screen">

    <!-- HORA SUPERIOR IZQUIERDA -->
    <div class="top-left-time">
        <div class="clock" id="clock-display">00:00</div>
        <div class="date" id="date-display">Día, Mes Año</div>
    </div>

    <!-- INDICADOR PERMANENTE DE GUARDADO LOCAL -->
    <div class="notification-pill system-status">
        <i class="fa-solid fa-cloud-arrow-down pulse-icon" style="color: var(--accent);"></i>
        <span style="font-size: 0.95rem;">Guardado Local Activo</span>
    </div>

    <!-- MENSAJE PARPADEANTE INFERIOR -->
    <div class="blinking-instruction">
        <h2>Acerque su gafete al lector QR</h2>
        <p>El registro de asistencia se procesará automáticamente</p>
    </div>

    <!-- PANEL DE CONTROLES DE MUESTRA -->
    <div class="demo-controls">
        <button onclick="simularArranque()">Arranque</button>
        <button onclick="procesarEscaneoExitoso('Cristian Ramces', '20261014', 'Ingeniería de Software II')">Entrada</button>
        <button onclick="procesarDobleEscaneo('Cristian Ramces')">Doble Escaneo</button>
        <button onclick="mostrarError('El código no fue registrado, por favor intente de nuevo.')">Error</button>
        <button onclick="mostrarAvisoBD('Conexión inestable. Cambiando a SQLite...')">Aviso Base</button>
        <button onclick="showScreen('admin-screen')">Admin</button>
    </div>
</div>

<!-- 3A. PANTALLA DASHBOARD ALUMNO (ENTRADA) -->
<div id="dashboard-screen" class="screen">
    <div class="student-card glass-panel">
        <div class="card-glow-line"></div>

        <div class="student-info">
            <div class="status-badge"><i class="fa-solid fa-check-circle"></i> Acceso de Entrada Registrado</div>
            <h1 id="student-name-in">Cargando...</h1>
            <p class="matricula" id="student-id-in">Matrícula: ---</p>

            <div class="class-info">
                <p style="margin: 0; font-size: 1.2rem; color: var(--text-muted);">Clase Actual<strong id="student-class">---</strong></p>
            </div>

            <!-- BOTÓN PARA VER INFO ACADÉMICA -->
            <button class="action-btn info-btn" style="margin-top: 40px; font-size: 1rem; padding: 15px 30px; border-radius: 30px;" onclick="mostrarInfoAcademica()">
                Ver mi Información Académica
            </button>
        </div>
    </div>
    <div class="timeout-bar-container"><div class="timeout-bar" id="timeout-bar-in"></div></div>
</div>

<!-- 3B. PANTALLA EXCEPCIÓN: DOBLE ESCANEO (OPCIONES) -->
<div id="double-scan-screen" class="screen">
    <div class="glass-panel" style="padding: 70px 80px; text-align: center; max-width: 800px;">
        <div class="card-glow-line" style="background: rgba(255,255,255,0.5); box-shadow: 0 0 20px rgba(255,255,255,0.2);"></div>
        <h2 id="ds-name" style="font-size: 3rem; margin-bottom: 20px;">Hola de nuevo, ---</h2>
        <p style="font-size: 1.3rem; color: var(--text-muted);">El sistema detecta que ya tienes un registro de entrada previo.</p>
        <p style="font-size: 1.4rem; color: var(--text-main); margin-bottom: 45px; margin-top: 10px;">¿Qué deseas realizar?</p>

        <div style="display: flex; gap: 20px; justify-content: center;">
            <button class="action-btn exit-btn" onclick="registrarSalida()">Registrar Salida</button>
            <button class="action-btn info-btn" onclick="mostrarInfoAcademica()">Ver mi Información</button>
        </div>
    </div>
    <div class="timeout-bar-container"><div class="timeout-bar" id="timeout-bar-ds" style="transition: width 10s linear; background-color: white; box-shadow: 0 0 10px rgba(255,255,255,0.5);"></div></div>
</div>

<!-- 3C. PANTALLA DE DESPEDIDA (SALIDA) -->
<div id="farewell-screen" class="screen">
    <div class="student-card glass-panel">
        <div class="card-glow-line"></div>

        <div class="student-info">
            <div class="status-badge"><i class="fa-solid fa-arrow-right-from-bracket"></i> Acceso de Salida Registrado</div>
            <h1 id="student-name-out" style="font-size: 4rem;">¡Hasta pronto!</h1>
            <p style="font-size: 1.4rem; color: var(--text-muted); margin-top: 10px;">Tu hora de salida ha sido guardada exitosamente.</p>

            <div class="class-info" style="background: rgba(244, 63, 94, 0.1); border-color: rgba(244, 63, 94, 0.2); margin-top: 30px;">
                <p style="margin: 0; font-size: 1.3rem; color: white;">¡Que tengas un excelente día, nos vemos mañana!</p>
            </div>
        </div>
    </div>
    <div class="timeout-bar-container"><div class="timeout-bar" id="timeout-bar-out"></div></div>
</div>

<!-- 3D. PANTALLA DE INFORMACIÓN ACADÉMICA INTERACTIVA -->
<div id="academic-info-screen" class="screen">
    <div class="academic-panel glass-panel">
        <div class="card-glow-line"></div>
        <h2 style="text-align: center; font-size: 2.5rem;">Panel Académico del Estudiante</h2>
        <p id="academic-student-name" style="color: var(--accent); font-size: 1.2rem; text-align: center; margin-top: 10px; font-weight: 500;">---</p>
        

        <button class="close-btn" onclick="volverAIdle()">Cerrar y Volver al Inicio</button>
    </div>
    <div class="timeout-bar-container"><div class="timeout-bar" id="timeout-bar-info" style="transition: width 20s linear;"></div></div>
</div>

<!-- 4. PANTALLA ADMIN -->
<div id="admin-screen" class="screen">
    <div class="pin-pad glass-panel">
        <div class="card-glow-line" style="background: #ffffff; box-shadow: 0 0 20px rgba(255,255,255,0.5);"></div>
        <h2 style="margin-bottom: 30px; font-size: 2.2rem;">Panel de los papireys</h2>

        <div class="admin-form">
            <label>Usuario</label>
            <input type="text" placeholder="Ej. administrador">

            <label>Contraseña</label>
            <input type="password" placeholder="••••••••">
        </div>

        <div class="admin-actions">
            <button class="admin-btn btn-cancel" onclick="volverAIdle()">Cancelar</button>
            <button class="admin-btn btn-login" onclick="mostrarWarning('Función de login en desarrollo')">Ingresar</button>
        </div>
    </div>
</div>

<!-- ================= JAVASCRIPT: LÓGICA DE INTERFAZ ================= -->
<script>
    let globalTimeoutId;
    let alumnoActual = "";

    // NAVEGACIÓN Y RESET DE BARRAS
    function showScreen(screenId) {
        clearTimeout(globalTimeoutId);
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(screenId).classList.add('active');
    }

    function resetProgressBar(barId, durationMs) {
        const bar = document.getElementById(barId);
        if(!bar) return;
        bar.style.transition = 'none';
        bar.style.width = '100%';
        setTimeout(() => {
            bar.style.transition = `width ${durationMs}ms linear`;
            bar.style.width = '0%';
        }, 50);
    }

    // RELOJ EN TIEMPO REAL
    function updateClock() {
        const now = new Date();
        let hours = now.getHours().toString().padStart(2, '0');
        let minutes = now.getMinutes().toString().padStart(2, '0');
        document.getElementById('clock-display').innerText = `${hours}:${minutes}`;

        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        // Capitalizar la primera letra del día
        let dateStr = now.toLocaleDateString('es-ES', options);
        dateStr = dateStr.charAt(0).toUpperCase() + dateStr.slice(1);
        document.getElementById('date-display').innerText = dateStr;
    }
    setInterval(updateClock, 1000);
    updateClock();

    // SIMULACIÓN DE ARRANQUE
    function simularArranque() {
        showScreen('splash-screen');
        globalTimeoutId = setTimeout(() => { showScreen('idle-screen'); }, 3000);
    }
    simularArranque();

    // 1: ACCESO NORMAL (ENTRADA)
    function procesarEscaneoExitoso(nombre, matricula, clase) {
        alumnoActual = nombre;
        document.getElementById('student-name-in').innerText = nombre;
        document.getElementById('student-id-in').innerText = `Matrícula: ${matricula}`;
        document.getElementById('student-class').innerText = clase;

        showScreen('dashboard-screen');
        resetProgressBar('timeout-bar-in', 5000);
        globalTimeoutId = setTimeout(() => { showScreen('idle-screen'); }, 5000);
    }

    // 2: EXCEPCIÓN (DOBLE ESCANEO)
    function procesarDobleEscaneo(nombre) {
        alumnoActual = nombre;
        document.getElementById('ds-name').innerText = `Hola de nuevo, ${nombre}`;

        showScreen('double-scan-screen');
        resetProgressBar('timeout-bar-ds', 10000);
        globalTimeoutId = setTimeout(() => { showScreen('idle-screen'); }, 10000);
    }

    // ACCIÓN: REGISTRAR SALIDA
    function registrarSalida() {
        document.getElementById('student-name-out').innerText = `¡Hasta pronto, \n${alumnoActual}!`;

        showScreen('farewell-screen');
        resetProgressBar('timeout-bar-out', 4000);
        globalTimeoutId = setTimeout(() => { showScreen('idle-screen'); }, 4000);
    }

    // ACCIÓN: VER INFORMACIÓN ACADÉMICA
    function mostrarInfoAcademica() {
        document.getElementById('academic-student-name').innerText = `Expediente de: ${alumnoActual}`;

        showScreen('academic-info-screen');
        resetProgressBar('timeout-bar-info', 20000);
        globalTimeoutId = setTimeout(() => { showScreen('idle-screen'); }, 20000);
    }

    // WARNINGS Y ERRORES
    function mostrarError(mensaje) {
        const overlay = document.getElementById('error-overlay');
        const notif = document.getElementById('error-notification');

        if(mensaje) document.getElementById('error-msg').innerText = mensaje;

        overlay.classList.remove('flash');
        void overlay.offsetWidth;
        overlay.classList.add('flash');

        notif.classList.add('show');
        setTimeout(() => { notif.classList.remove('show'); }, 4000);
    }

    function mostrarAvisoBD(mensaje) {
        const warning = document.getElementById('connection-warning');
        if(mensaje) document.getElementById('warning-msg').innerText = mensaje;

        warning.classList.add('show');
        setTimeout(() => { warning.classList.remove('show'); }, 5000);
    }

    // LÓGICA DE ADMIN (Gesto Secreto)
    let clicks = 0;
    function adminClicks() {
        clicks++;
        if(clicks >= 5) {
            showScreen('admin-screen');
            clicks = 0;
        }
        setTimeout(() => { clicks = 0; }, 2000);
    }

    function volverAIdle() {
        showScreen('idle-screen');
    }
</script>
</body>
</html>
